# DeepSeek API — https://api-docs.deepseek.com/
DEEPSEEK_API_KEY=sk-your-key-here

# Anthropic-compatible endpoint (recommended)
DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic
DEEPSEEK_API_FORMAT=anthropic

# OpenAI-compatible endpoint (alternative)
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_API_FORMAT=openai

# Beta features: Chat Prefix Completion, strict Function Calling
# Requires OpenAI format — switches base to https://api.deepseek.com/beta
# DEEPSEEK_USE_BETA=true