{
  "scopeName": "source.moonfile",
  "patterns": [
    { "include": "#comment" },
    { "include": "#package" },
    { "include": "#section-header" },
    { "include": "#nested-header" },
    { "include": "#env-call" },
    { "include": "#key-value" },
    { "include": "#dependency-entry" },
    { "include": "#string" },
    { "include": "#boolean" },
    { "include": "#number" }
  ],
  "repository": {
    "comment": {
      "patterns": [
        { "match": "#.*$", "name": "comment.line.number-sign.moonfile" },
        { "match": "--.*$", "name": "comment.line.double-dash.moonfile" }
      ]
    },
    "package": {
      "match": "\\b(package)\\s+(\"[^\"]*\")",
      "captures": {
        "1": { "name": "keyword.declaration.moonfile" },
        "2": { "name": "string.quoted.double.moonfile" }
      }
    },
    "section-header": {
      "match": "^(dependencies|targets|providers|paths|models|prompts|runtime):\\s*$",
      "captures": {
        "1": { "name": "entity.name.section.moonfile" }
      }
    },
    "nested-header": {
      "match": "^\\s{2,}(deepseek|storm|worker_pool|memory|retries):\\s*$",
      "captures": {
        "1": { "name": "entity.name.section.moonfile" }
      }
    },
    "env-call": {
      "match": "\\b(env)\\s*\\(\\s*(\"[^\"]+\")\\s*\\)",
      "captures": {
        "1": { "name": "support.function.moonfile" },
        "2": { "name": "string.quoted.double.environment.moonfile" }
      }
    },
    "key-value": {
      "match": "^\\s*([a-zA-Z0-9_.-]+)(:)(\\s+)(.+)$",
      "captures": {
        "1": { "name": "variable.other.key.moonfile" },
        "2": { "name": "punctuation.separator.key-value.moonfile" },
        "3": { "name": "" },
        "4": { "patterns": [{ "include": "#value" }] }
      }
    },
    "dependency-entry": {
      "match": "^\\s+(Core\\.[A-Za-z][A-Za-z0-9.]*)\\s*$",
      "captures": {
        "1": { "name": "support.type.module.moonfile" }
      }
    },
    "value": {
      "patterns": [
        { "include": "#env-call" },
        { "include": "#string" },
        { "include": "#boolean" },
        { "include": "#number" },
        {
          "match": "\\b(openai|anthropic|file|https?)\\b",
          "name": "constant.language.moonfile"
        },
        {
          "match": "[A-Za-z0-9_./\\\\-]+",
          "name": "string.unquoted.path.moonfile"
        }
      ]
    },
    "string": {
      "match": "\"([^\"\\\\]|\\\\.)*\"",
      "name": "string.quoted.double.moonfile"
    },
    "boolean": {
      "match": "\\b(true|false)\\b",
      "name": "constant.language.boolean.moonfile"
    },
    "number": {
      "match": "\\b[0-9]+(?:\\.[0-9]+)?\\b",
      "name": "constant.numeric.moonfile"
    }
  }
}