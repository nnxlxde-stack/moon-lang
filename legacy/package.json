{
  "name": "moon-lang-legacy",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "bun test",
    "check": "bun run packages/cli/src/index.ts check",
    "run": "bun run packages/cli/src/index.ts run",
    "build": "bun run packages/cli/src/index.ts build",
    "vscode:build": "bun run --filter vscode-moon build",
    "vscode:package": "bun run --filter vscode-moon package"
  }
}